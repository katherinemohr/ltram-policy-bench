#!/bin/sh

INTERACTIVE=0
HIST=0
RUN_NAME=""
RUN_DIR=""
SWEEP_PID=""

detect_interactive() {
    if grep -q "interactive=1" /proc/cmdline; then
        echo "Interactive mode detected: skipping workload and shutdown."
        INTERACTIVE=1
    fi
}

detect_hist() {
    if grep -q "ltram_hist=1" /proc/cmdline; then
        echo "Histogram mode: dirty_sweep will run alongside the workload."
        HIST=1
    fi
    SWEEP_INTERVAL_MS=$(grep -o 'ltram_sweep_interval_ms=[^ ]*' /proc/cmdline | cut -d= -f2)
    SWEEP_INTERVAL_MS=${SWEEP_INTERVAL_MS:-100}
}

resolve_run_dir() {
    RUN_NAME=$(grep -o 'ltram_run=[^ ]*' /proc/cmdline | cut -d= -f2)
    if [ -z "$RUN_NAME" ]; then
        RUN_NAME="default_$(date +%s)"
    fi
    RUN_DIR="/mnt/results/runs/$RUN_NAME"
    mkdir -p "$RUN_DIR"
    echo "Run dir: $RUN_DIR"
}

start_dirty_sweep() {
    # $1 = target pid
    # $2 = optional output basename (default "dirty_sweep")
    #      Used for phase splits (e.g. "dirty_sweep_load" + "dirty_sweep_run")
    #      so different phases of a workload can be profiled separately.
    [ "$HIST" -eq 1 ] || return 0
    local target_pid=$1
    local out_base=${2:-dirty_sweep}
    /mnt/workloads/monitoring/dirty_sweep "$target_pid" \
        "$RUN_DIR/${out_base}.csv" "$SWEEP_INTERVAL_MS" 2> "$RUN_DIR/${out_base}.log" &
    SWEEP_PID=$!
    echo "[hist] dirty_sweep pid=$SWEEP_PID, target pid=$target_pid, "\
"out=${out_base}.csv"
}

stop_dirty_sweep() {
    [ "$HIST" -eq 1 ] || return 0
    if [ -n "$SWEEP_PID" ]; then
        kill "$SWEEP_PID" 2>/dev/null
        wait "$SWEEP_PID" 2>/dev/null
        SWEEP_PID=""
        echo "[hist] dirty_sweep stopped"
    fi
}

start_run() {
    mkdir -p /mnt/workloads /mnt/results /mnt/inputs

    mount -t 9p -o trans=virtio workloads /mnt/workloads
    mount -t 9p -o trans=virtio results /mnt/results
    mount -t 9p -o trans=virtio inputs /mnt/inputs

    resolve_run_dir

    numactl --hardware > "$RUN_DIR/numa-topology.txt"
    cp /proc/cmdline "$RUN_DIR/cmdline.txt"
    cp /proc/vmstat "$RUN_DIR/vmstat-before.txt"

    echo 1 > /proc/sys/vm/overcommit_memory

    sh /mnt/workloads/monitoring/meminfo_log.sh > "$RUN_DIR/meminfo.csv" &
}

run_workload() {
    if [ "$INTERACTIVE" -eq 1 ]; then
        echo "Interactive mode: not running any workload."
        return 0
    fi

    echo "Kernel boot parameter requested workload: $1"

    case "$1" in
        matmul) matmul ;;
        gapbs) gapbs_pagerank ;;
        redis) redis ;;
        duckdb) duckdb ;;
        *) echo "Unknown workload: $1. Defaulting to matmul."; matmul ;;
    esac
}

matmul() {
    # Allow iteration count override via kernel cmdline (LTRAM_MATMUL_ITERS).
    # Default is the binary's compiled-in ITERS=10.
    #
    # Load/run split is DETERMINISTIC: matrix_multiply.c writes a marker
    # file when the alloc + fill_random initialization finishes (right
    # before the multiply loop). We poll for it instead of guessing a
    # wallclock duration — same approach as the gapbs split.
    local mm_iters=$(grep -o 'ltram_matmul_iters=[^ ]*' /proc/cmdline | cut -d= -f2)
    local marker=/tmp/ltram_matmul_init_done
    rm -f "$marker"
    local timeout_ds=3000     # 5 minutes in 0.1s ticks (init is fast)

    echo "Starting Matrix Multiplication workload (iters=${mm_iters:-default}, deterministic split: $marker)..."
    LTRAM_MATMUL_INIT_DONE_MARKER="$marker" \
        numactl --cpunodebind=0 --membind=0 /mnt/workloads/matmul/matrix_multiply $mm_iters \
        > "$RUN_DIR/workload-stdout.txt" 2>&1 &
    local pid=$!
    sleep 0.5    # let numactl exec into matrix_multiply (race fix)

    # === LOAD phase: NUMA alloc + fill_random for both matrices ===
    start_dirty_sweep "$pid" "dirty_sweep_load"
    local waited=0
    while [ ! -f "$marker" ]; do
        if ! kill -0 "$pid" 2>/dev/null; then
            echo "[matmul] process exited before marker — single CSV (load only)"
            stop_dirty_sweep
            return 0
        fi
        if [ $waited -ge $timeout_ds ]; then
            echo "[matmul] WARNING: init marker not seen in $((timeout_ds/10))s — proceeding anyway"
            break
        fi
        sleep 0.1
        waited=$((waited + 1))
    done
    stop_dirty_sweep
    echo "[matmul] LOAD phase complete after ~$((waited / 10))s (saw $marker)"

    if ! kill -0 "$pid" 2>/dev/null; then
        echo "[matmul] process exited at init→multiply boundary — only load CSV"
        return 0
    fi

    # === RUN phase: matmul iterations (read A, write C) ===
    start_dirty_sweep "$pid" "dirty_sweep"
    wait "$pid"
    stop_dirty_sweep
    echo "Matrix Multiplication complete (deterministic load/run split)."
}

gapbs_pagerank() {
    # GAPbs flags overridable via kernel cmdline:
    #   ltram_gapbs_graph   — default 20 = 2^20 vertices
    #   ltram_gapbs_trials  — number of independent trials
    #   ltram_gapbs_iters   — PR iterations per trial
    #
    # Load/run split is DETERMINISTIC: our patched pr.cc writes a marker
    # file when b.MakeGraph() returns (= build phase complete). We watch
    # for the marker instead of sleeping a fixed time, so the boundary
    # always lands at the actual build→PR transition regardless of graph
    # size or system load. No more guessing load_secs per graph size.
    local g=$(grep -o 'ltram_gapbs_graph=[^ ]*'  /proc/cmdline | cut -d= -f2)
    local n=$(grep -o 'ltram_gapbs_trials=[^ ]*' /proc/cmdline | cut -d= -f2)
    local i=$(grep -o 'ltram_gapbs_iters=[^ ]*'  /proc/cmdline | cut -d= -f2)
    g=${g:-20}
    local args="-g $g"
    [ -n "$n" ] && args="$args -n $n"
    [ -n "$i" ] && args="$args -i $i"

    local marker=/tmp/ltram_gapbs_build_done
    rm -f "$marker"
    # Safety timeout: cap waiting in case the marker never lands (e.g.
    # workload exited unexpectedly). 10 min is enough for g=24 builds.
    local timeout_ds=6000     # tenths of a second

    echo "Running GAPbs PageRank with args: $args  (deterministic split: $marker)"
    LTRAM_GAPBS_BUILD_DONE_MARKER="$marker" \
        numactl --cpunodebind=0 --membind=0 /mnt/workloads/pr $args \
        > "$RUN_DIR/workload-stdout.txt" 2>&1 &
    local pid=$!
    sleep 0.5    # let numactl exec into /mnt/workloads/pr (race fix)

    # === LOAD phase: graph generate + build (mostly writes) ===
    start_dirty_sweep "$pid" "dirty_sweep_load"
    local waited=0
    while [ ! -f "$marker" ]; do
        if ! kill -0 "$pid" 2>/dev/null; then
            echo "[gapbs] process exited before marker — single CSV (load only)"
            stop_dirty_sweep
            return 0
        fi
        if [ $waited -ge $timeout_ds ]; then
            echo "[gapbs] WARNING: build marker not seen in $((timeout_ds/10))s — proceeding anyway"
            break
        fi
        sleep 0.1
        waited=$((waited + 1))
    done
    stop_dirty_sweep
    local build_secs=$((waited / 10))
    echo "[gapbs] LOAD phase complete after ~${build_secs}s (saw $marker)"

    if ! kill -0 "$pid" 2>/dev/null; then
        echo "[gapbs] process exited at build→run boundary — only load CSV"
        return 0
    fi

    # === RUN phase: PR trials (mostly reads) ===
    start_dirty_sweep "$pid" "dirty_sweep"
    wait "$pid"
    stop_dirty_sweep
    echo "PageRank complete (deterministic load/run split)."
}

duckdb() {
    local tpch=$(grep -o 'ltram_duckdb_tpch=[^ ]*' /proc/cmdline | cut -d= -f2)
    tpch=${tpch:-0}

    local marker=/tmp/ltram_duckdb_load_done
    rm -f "$marker"
    local timeout_ds=6000   # 10 min — TPC-H dbgen at large SF can be slow

    local bench_args=""

    if [ "$tpch" = "1" ]; then
        local sf=$(grep -o 'ltram_duckdb_tpch_sf=[^ ]*' /proc/cmdline | cut -d= -f2)
        local query=$(grep -o 'ltram_duckdb_tpch_query=[^ ]*' /proc/cmdline | cut -d= -f2)
        local ops=$(grep -o 'ltram_duckdb_ops=[^ ]*' /proc/cmdline | cut -d= -f2)
        bench_args="-T"
        [ -n "$sf" ]    && bench_args="$bench_args -f $sf"
        [ -n "$query" ] && bench_args="$bench_args -q $query"
        [ -n "$ops" ]   && bench_args="$bench_args -n $ops"
        echo "Starting DuckDB TPC-H benchmark (sf=${sf:-1.0} query=${query:-all} rounds=${ops:-10})..."
    else
        local records=$(grep -o 'ltram_duckdb_records=[^ ]*' /proc/cmdline | cut -d= -f2)
        local ops=$(grep -o 'ltram_duckdb_ops=[^ ]*' /proc/cmdline | cut -d= -f2)
        local read_ratio=$(grep -o 'ltram_duckdb_read_ratio=[^ ]*' /proc/cmdline | cut -d= -f2)
        local dist=$(grep -o 'ltram_duckdb_dist=[^ ]*' /proc/cmdline | cut -d= -f2)
        records=${records:-1000000}
        ops=${ops:-100000}
        read_ratio=${read_ratio:-1.0}
        dist=${dist:-uniform}
        bench_args="-r $records -n $ops -R $read_ratio -D $dist"
        echo "Starting DuckDB YCSB benchmark (records=$records ops=$ops read_ratio=$read_ratio dist=$dist)..."
    fi

    LTRAM_DUCKDB_LOAD_DONE_MARKER="$marker" \
        numactl --cpunodebind=0 --membind=0 \
        /mnt/workloads/duckdb/bench $bench_args \
        > "$RUN_DIR/workload-stdout.txt" 2>&1 &
    local pid=$!
    sleep 0.5

    # === LOAD phase: bulk insert (YCSB) or dbgen (TPC-H) ===
    start_dirty_sweep "$pid" "dirty_sweep_load"
    local waited=0
    while [ ! -f "$marker" ]; do
        if ! kill -0 "$pid" 2>/dev/null; then
            echo "[duckdb] process exited before marker — single CSV (load only)"
            stop_dirty_sweep
            return 0
        fi
        if [ $waited -ge $timeout_ds ]; then
            echo "[duckdb] WARNING: load marker not seen in $((timeout_ds/10))s — proceeding anyway"
            break
        fi
        sleep 0.1
        waited=$((waited + 1))
    done
    stop_dirty_sweep
    echo "[duckdb] LOAD phase complete after ~$((waited / 10))s"

    if ! kill -0 "$pid" 2>/dev/null; then
        echo "[duckdb] process exited at load→run boundary — only load CSV"
        return 0
    fi

    # === RUN phase: queries ===
    start_dirty_sweep "$pid" "dirty_sweep"
    wait "$pid"
    stop_dirty_sweep
    echo "DuckDB benchmark complete."
}

redis() {
    export LD_LIBRARY_PATH=/mnt/workloads/YCSB-C/install:$LD_LIBRARY_PATH
    ip link set lo up

    echo "Starting Redis server on Node 0..."
    numactl --cpunodebind=0 --membind=0 redis-server --save "" --daemonize yes
    sleep 2
    local redis_pid=$(pidof redis-server)
    echo "redis-server pid=$redis_pid"

    # Spec file selection: read ltram_redis_spec from the kernel command line,
    # default to workloadmini.spec for backward compatibility. The host can
    # set LTRAM_REDIS_SPEC=workloadlong.spec (or any other spec) to swap in
    # a different operationcount / mix without touching this script.
    SPEC=$(grep -o 'ltram_redis_spec=[^ ]*' /proc/cmdline | cut -d= -f2)
    SPEC=${SPEC:-workloadmini.spec}
    WORKLOAD_PATH="/mnt/workloads/YCSB-C/workloads/$SPEC"
    echo "Using YCSB workload spec: $SPEC"

    # === PHASE 1 (LOAD): dedicated dirty_sweep → dirty_sweep_load.csv ===
    # The load phase fills Redis from empty: every page faulted in & written
    # exactly once. Profile this separately so the steady-state run-phase
    # statistics aren't diluted by the one-time load burst.
    start_dirty_sweep "$redis_pid" "dirty_sweep_load"
    echo "Phase 1: Loading data into Redis..."
    /mnt/workloads/YCSB-C/ycsbc -db redis -P "$WORKLOAD_PATH" \
        > "$RUN_DIR/ycsb-load.txt" 2>&1
    stop_dirty_sweep

    # === PHASE 2 (RUN): default-named dirty_sweep → dirty_sweep.csv ===
    # The default basename keeps the existing analysis pipeline happy (it
    # reads dirty_sweep.csv) while phase-1 data lives alongside as
    # dirty_sweep_load.csv for explicit cold-start analysis.
    start_dirty_sweep "$redis_pid" "dirty_sweep"
    echo "Phase 2: Running operations..."
    /mnt/workloads/YCSB-C/ycsbc -db redis -P "$WORKLOAD_PATH" \
        > "$RUN_DIR/ycsb-run.txt" 2>&1
    stop_dirty_sweep
}

end_run() {
    cp /proc/vmstat "$RUN_DIR/vmstat-after.txt"

    for node in 0 1; do
        cat /sys/devices/system/node/node${node}/meminfo \
            > "$RUN_DIR/node${node}-meminfo.txt"
    done

    sh /mnt/workloads/monitoring/meminfo_log.sh --end "$RUN_DIR/meminfo.csv" \
        > "$RUN_DIR/meminfo_summary.txt"

    cat /sys/kernel/debug/ltram/stats > "$RUN_DIR/ltram-stats.txt" 2>/dev/null || true

    if [ "$INTERACTIVE" -eq 1 ]; then
        echo "Interactive mode: leaving VM running."
        return 0
    fi

    echo "Workload complete. Powering off..."
    poweroff -f
}

SELECTED=$(grep -o 'ltram_workload=[^ ]*' /proc/cmdline | cut -d= -f2)

case "$1" in
    start)
        detect_interactive
        detect_hist
        start_run
        run_workload $SELECTED
        end_run
        ;;
    *)
        echo "Usage: $0 {start}"
        exit 1
        ;;
esac
